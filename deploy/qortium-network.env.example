# Qortium Network auto-logging configuration.
# Copy to deploy/qortium-network.env (gitignored) and edit for the host.
# Both user units read this file. All keys use the QORTIUM_NETWORK_ prefix.
#
# Paths for the archive, payload, and state default to <repo>/target/... and
# usually need no override. You mainly need the node key + account paths, since
# their defaults assume a dev checkout under ~/git.

# Query the local node over localhost instead of SSH (this host IS that node).
QORTIUM_NETWORK_LOCAL_NODE=netcup

# Core API key + signing account that owns the "Network" QDN name.
QORTIUM_NETWORK_NODE_API_KEY_PATH=/home/qortium/qortium/preview/apikey.txt
QORTIUM_NETWORK_PREVIEW_ACCOUNTS_PATH=/home/qortium/qortium/preview/secrets/initial-minting-accounts.json
QORTIUM_NETWORK_PREVIEW_ACCOUNT_ROLE=local

# --- Optional overrides (sensible defaults shown) --------------------------
# QORTIUM_NETWORK_NODE_API_URL=http://127.0.0.1:24891
# QORTIUM_NETWORK_MIN_GAP_HOURS=8
# QORTIUM_NETWORK_RETENTION_DAYS=14
# QORTIUM_NETWORK_COLLECT_TIMEOUT=8
# QORTIUM_NETWORK_ARCHIVE_DIR=/home/qortium/qortium-network/target/preview-topology
# QORTIUM_NETWORK_QDN_DATA_PATH=/home/qortium/qortium-network/target/qdn-topology-data
# QORTIUM_NETWORK_AUTO_STATE_PATH=/home/qortium/qortium-network/target/auto-publish-state.json
# QORTIUM_NETWORK_PYTHON=python3
