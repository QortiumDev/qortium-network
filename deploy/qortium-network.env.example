# Qortium Network auto-logging configuration.
# Copy to /etc/qortium-network.env on the host and edit the paths.
# Both systemd units read this file. All keys use the QORTIUM_NETWORK_ prefix.

# --- Collection (every ~10 min) -------------------------------------------
# Query the local node over localhost instead of SSH (this host IS netcup).
QORTIUM_NETWORK_LOCAL_NODE=netcup
QORTIUM_NETWORK_ARCHIVE_DIR=/opt/qortium-network/target/preview-topology
QORTIUM_NETWORK_RETENTION_DAYS=14
QORTIUM_NETWORK_COLLECT_TIMEOUT=8

# --- Publishing (~2x/day) -------------------------------------------------
QORTIUM_NETWORK_QDN_DATA_PATH=/opt/qortium-network/target/qdn-topology-data
QORTIUM_NETWORK_AUTO_STATE_PATH=/opt/qortium-network/target/auto-publish-state.json
# Minimum hours between published records (enforced from the last selected
# record's timestamp, so records never cluster across day boundaries).
QORTIUM_NETWORK_MIN_GAP_HOURS=8

# --- Node API + signing account (publishing only) -------------------------
QORTIUM_NETWORK_NODE_API_URL=http://127.0.0.1:24891
QORTIUM_NETWORK_NODE_API_KEY_PATH=/opt/qortium/apikey.txt
QORTIUM_NETWORK_PREVIEW_ACCOUNTS_PATH=/opt/qortium-network/secrets/initial-minting-accounts.json
# Role in the accounts file that owns the QDN name "Network".
QORTIUM_NETWORK_PREVIEW_ACCOUNT_ROLE=local

# --- Optional -------------------------------------------------------------
# QORTIUM_NETWORK_PYTHON=python3
